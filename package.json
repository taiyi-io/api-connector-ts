{
  "name": "@taiyi-io/api-connector-ts",
  "version": "0.12.0",
  "description": "Typescript connector to Taiyi control API",
  "keywords": [
    "cloud"
  ],
  "homepage": "https://github.com/taiyi-io/api-connector-ts#readme",
  "bugs": {
    "url": "https://github.com/taiyi-io/api-connector-ts/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taiyi-io/api-connector-ts.git"
  },
  "license": "MIT",
  "author": "Akumas",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "source": "./src/index.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint .",
    "test": "vitest",
    "prepublishOnly": "pnpm run build"
  },
  "packageManager": "pnpm@10.5.2",
  "devDependencies": {
    "@microsoft/tsdoc-config": "^0.18.1",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "eslint-plugin-tsdoc": "^0.5.2",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@noble/ed25519": "^3.0.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@sindresorhus/fnv1a": "^3.1.0",
    "copy-to-clipboard": "^3.3.3",
    "dotenv": "^17.3.1"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  }
}
