{
  "compilerOptions": {
    "target": "ES6", // 编译目标版本
    "module": "CommonJS", // 模块系统（兼容Node.js）
    "outDir": "dist", // 输出目录
    "rootDir": "src", // 源代码目录
    "strict": true, // 开启严格模式
    // 禁止 tsc 在 CJS 输出首行注入 "use strict"，避免把 "use server" directive 挤到第二行
    // 导致 Next 16 / SWC 不识别为 Server Action 模块。类型检查的严格性由 strict:true 的
    // 其他子项（noImplicitAny / strictNullChecks 等）继续保证。
    "alwaysStrict": false,
    "declaration": true, // 生成类型声明文件（.d.ts）
    "declarationDir": "dist", // 类型声明文件输出目录
    "esModuleInterop": true, // 兼容ES模块和CommonJS
    "skipLibCheck": true, // 跳过库文件检查
    "forceConsistentCasingInFileNames": true // 强制文件名大小写一致
  },
  "include": ["src/**/*"], // 需要编译的文件
  "exclude": ["node_modules", "dist", "**/*.test.ts"] // 排除文件
}